{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "alexkramse/filament-openapi-docs",
    "description": "Render Scramble OpenAPI documentation inside a Filament panel.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Kramarenko\\FilamentOpenApiDocs\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kramarenko\\FilamentOpenApiDocs\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.3",
        "dedoc/scramble": "^0.13.30",
        "filament/filament": "^5.0",
        "illuminate/support": "^13.0",
        "spatie/laravel-package-tools": "^1.92"
    },
    "require-dev": {
        "laravel/framework": "^13.0",
        "laravel/pint": "^1.29",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Kramarenko\\FilamentOpenApiDocs\\FilamentOpenApiDocsServiceProvider"
            ]
        }
    },
    "scripts": {
        "pint": [
            "vendor/bin/pint"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
